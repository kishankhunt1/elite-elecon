---
import Layout from "../layouts/Layout.astro";
---

<Layout 
  title="Our Engineering Services | Civil, Mechanical, HVAC & Solar"
  description="Elite Elecon offers comprehensive engineering solutions, including civil construction, mechanical services, industrial HVAC systems, and solar energy projects."
>
  <!-- Hero Section -->
  <section class="relative bg-gradient-to-r from-primary-900 to-primary-800 text-white py-16 md:py-24">
    <div class="absolute inset-0">
      <img 
        src="/project-page-bg.webp"
        alt="Services Background"
        class="w-full h-full object-cover opacity-20"
      />
    </div>
    <div class="container relative mx-auto px-4 md:px-8">
      <div class="max-w-3xl">
        <div class="inline-flex items-center px-4 py-2 bg-white/20 text-white rounded-full text-sm font-semibold mb-4">
          Our Services
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Comprehensive <span class="text-primary-300">Engineering Solutions</span>
        </h1>
        <p class="text-lg md:text-xl text-primary-100 mb-8">
          We provide end-to-end engineering solutions across Civil, Mechanical, Electrical & HVAC domains. 
          With 10+ years of experience, we deliver excellence in every project.
        </p>
      </div>
    </div>
  </section>

  <!-- Services Section - Zigzag Pattern -->
  <section id="industrial" class="section bg-white">
    <div class="container mx-auto px-4 md:px-8 space-y-12">
      <!-- Civil Field -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img 
              src="/pages/services/image1.jpg"
              alt="Civil Construction"
              class="w-full h-[400px] md:h-[500px] object-cover"
            />
            <div class="absolute top-4 left-4">
              <span class="inline-flex items-center px-4 py-2 bg-primary-500 text-white text-sm font-semibold rounded-full">
                <span class="mr-2 text-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 32 32"><rect width="32" height="32" fill="none"/><path fill="currentColor" d="M4 4a1 1 0 0 1 1-1h22a1 1 0 1 1 0 2h-3c0 .556-.404 1-.91 1h-.59v3.09c.85.23 1.48 1.02 1.48 1.94c0 .696-.36 1.312-.903 1.67l.92 1.3h4.489a.51.51 0 0 1 .514.5a.5.5 0 0 1-.504.5H28v3h.486a.51.51 0 0 1 .514.5a.51.51 0 0 1-.514.5h-1.018a.49.49 0 0 1-.208.48c-.09.06-.19.09-.29.09c-.16 0-.31-.07-.41-.21l-.255-.36h-8.65l-.255.36c-.1.14-.25.21-.41.21c-.1 0-.2-.03-.29-.09a.49.49 0 0 1-.208-.48h-.978a.51.51 0 0 1-.514-.5c0-.274.232-.5.514-.5H16v-3h-.486a.51.51 0 0 1-.514-.5c0-.274.232-.5.514-.5h4.45l.92-1.3a2 2 0 0 1-.904-1.67c0-.28.23-.5.5-.5c.28 0 .5.22.5.5c0 .36.193.678.481.854l.085-.12a.5.5 0 0 1 .079-.1a.5.5 0 0 1 .355-.147c.13-.001.26.05.355.147a.5.5 0 0 1 .08.1l.084.12c.288-.176.481-.494.481-.854c0-.55-.43-.99-.98-1c-.17 0-.33-.09-.42-.23a.44.44 0 0 1-.09-.27c0-.04 0-.07.01-.11V6h-.59c-.506 0-.91-.444-.91-1h-6v21h.75c.69 0 1.25.56 1.25 1.25V28h12.01c1.1 0 1.99.895 1.99 2H2c0-1.105.89-2 1.99-2H5v-.75c0-.69.56-1.25 1.25-1.25H7V5H5a1 1 0 0 1-1-1m4 3v2.191L12.382 7zm.618 19H13v-2.191zm3.764-3H8v2.191zM8.618 10H13V7.809zm3.764 1H8v2.191zm-3.764 3H13v-2.191zm3.764 1H8v2.191zm-3.764 3H13v-2.191zm3.764 1H8v2.191zm-3.764 3H13v-2.191zm13.264-8.972l-.688.972h1.572l-.688-.972a2 2 0 0 1-.196 0M19.256 15H17v3h.132zm-.893 3h7.234l-2.123-3h-2.988zm6.342-3l2.123 3H27v-3z"/></svg></span>
                Civil Field
              </span>
            </div>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4">
            Expertise Area
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
            Civil <span class="text-primary-600">Construction</span>
          </h2>
          <p class="text-lg text-slate-600 mb-6">
            Specialized civil construction services with precision engineering and quality assurance.
          </p>
          
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Sub Station Foundation</strong> - Mobile Tower Foundation, Railway OHE Foundation</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Bridge Work</strong> - Box Culvert, VUP, PUP construction</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Fencing Solutions</strong> - Forest Fencing, Railway Fencing, Solar Fencing, Road Precast Fencing</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Road Construction</strong> - RCC Road, CC Road, Trimix Road</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Water Management</strong> - Water Drainage, Pipeline Systems, Water Sump Construction</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Building Construction</strong> - All types of building works including residential, commercial & industrial</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Mechanical Field -->
      <div id="commercial" class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img 
              src="/project-page-bg.webp"
              alt="Mechanical Services"
              class="w-full h-[400px] md:h-[500px] object-cover"
            />
            <div class="absolute top-4 left-4">
              <span class="inline-flex items-center px-4 py-2 bg-primary-500 text-white text-sm font-semibold rounded-full">
                <span class="mr-2 text-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><g fill="currentColor"><path d="m207.86 123.18l16.78-21a99 99 0 0 0-10.07-24.29l-26.7-3a81 81 0 0 0-6.81-6.81l-3-26.71a99.4 99.4 0 0 0-24.3-10l-21 16.77a82 82 0 0 0-9.64 0l-21-16.78a99 99 0 0 0-24.21 10.07l-3 26.7a81 81 0 0 0-6.81 6.81l-26.71 3a99.4 99.4 0 0 0-10 24.3l16.77 21a82 82 0 0 0 0 9.64l-16.78 21a99 99 0 0 0 10.07 24.29l26.7 3a81 81 0 0 0 6.81 6.81l3 26.71a99.4 99.4 0 0 0 24.3 10l21-16.77a82 82 0 0 0 9.64 0l21 16.78a99 99 0 0 0 24.29-10.07l3-26.7a81 81 0 0 0 6.81-6.81l26.71-3a99.4 99.4 0 0 0 10-24.3l-16.77-21a82 82 0 0 0-.08-9.64M128 168a40 40 0 1 1 40-40a40 40 0 0 1-40 40" opacity="0.2"/><path d="M128 80a48 48 0 1 0 48 48a48.05 48.05 0 0 0-48-48m0 80a32 32 0 1 1 32-32a32 32 0 0 1-32 32m88-29.84q.06-2.16 0-4.32l14.92-18.64a8 8 0 0 0 1.48-7.06a107.6 107.6 0 0 0-10.88-26.25a8 8 0 0 0-6-3.93l-23.72-2.64q-1.48-1.56-3-3L186 40.54a8 8 0 0 0-3.94-6a107.3 107.3 0 0 0-26.25-10.86a8 8 0 0 0-7.06 1.48L130.16 40h-4.32L107.2 25.11a8 8 0 0 0-7.06-1.48a107.6 107.6 0 0 0-26.25 10.88a8 8 0 0 0-3.93 6l-2.64 23.76q-1.56 1.49-3 3L40.54 70a8 8 0 0 0-6 3.94a107.7 107.7 0 0 0-10.87 26.25a8 8 0 0 0 1.49 7.06L40 125.84v4.32L25.11 148.8a8 8 0 0 0-1.48 7.06a107.6 107.6 0 0 0 10.88 26.25a8 8 0 0 0 6 3.93l23.72 2.64q1.49 1.56 3 3L70 215.46a8 8 0 0 0 3.94 6a107.7 107.7 0 0 0 26.25 10.87a8 8 0 0 0 7.06-1.49L125.84 216q2.16.06 4.32 0l18.64 14.92a8 8 0 0 0 7.06 1.48a107.2 107.2 0 0 0 26.25-10.88a8 8 0 0 0 3.93-6l2.64-23.72q1.56-1.48 3-3l23.78-2.8a8 8 0 0 0 6-3.94a107.7 107.7 0 0 0 10.87-26.25a8 8 0 0 0-1.49-7.06Zm-16.1-6.5a74 74 0 0 1 0 8.68a8 8 0 0 0 1.74 5.48l14.19 17.73a91.6 91.6 0 0 1-6.23 15l-22.6 2.56a8 8 0 0 0-5.1 2.64a74 74 0 0 1-6.14 6.14a8 8 0 0 0-2.64 5.1l-2.51 22.58a91.3 91.3 0 0 1-15 6.23l-17.74-14.19a8 8 0 0 0-5-1.75h-.48a74 74 0 0 1-8.68 0a8.06 8.06 0 0 0-5.48 1.74l-17.78 14.2a91.6 91.6 0 0 1-15-6.23L82.89 187a8 8 0 0 0-2.64-5.1a74 74 0 0 1-6.14-6.14a8 8 0 0 0-5.1-2.64l-22.58-2.52a91.3 91.3 0 0 1-6.23-15l14.19-17.74a8 8 0 0 0 1.74-5.48a74 74 0 0 1 0-8.68a8 8 0 0 0-1.74-5.48L40.2 100.45a91.6 91.6 0 0 1 6.23-15L69 82.89a8 8 0 0 0 5.1-2.64a74 74 0 0 1 6.14-6.14A8 8 0 0 0 82.89 69l2.51-22.57a91.3 91.3 0 0 1 15-6.23l17.74 14.19a8 8 0 0 0 5.48 1.74a74 74 0 0 1 8.68 0a8.06 8.06 0 0 0 5.48-1.74l17.77-14.19a91.6 91.6 0 0 1 15 6.23L173.11 69a8 8 0 0 0 2.64 5.1a74 74 0 0 1 6.14 6.14a8 8 0 0 0 5.1 2.64l22.58 2.51a91.3 91.3 0 0 1 6.23 15l-14.19 17.74a8 8 0 0 0-1.74 5.53Z"/></g></svg></span>
                Mechanical Field
              </span>
            </div>
          </div>
        </div>
        
        <div class="order-1">
          <div class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4">
            Expertise Area
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
            Mechanical <span class="text-primary-600">Services</span>
          </h2>
          <p class="text-lg text-slate-600 mb-6">
            Professional mechanical engineering services with focus on precision, reliability, and efficiency.
          </p>
          
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Structural Project Work</strong> - Complete structural engineering solutions</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Maintenance Work</strong> - Preventive and corrective maintenance services</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Fabrication Services</strong> - Custom fabrication for industrial applications</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Erection Services</strong> - Professional equipment and structure erection</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Pipeline Specialists</strong> - Complete pipeline design, installation, and maintenance</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Electrical & HVAC Field -->
      <div id="hvac-and-electrical" class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <div class="order-2 lg:order-1">
          <div class="relative rounded-2xl overflow-hidden shadow-xl">
            <img 
              src="/pages/services/image2.png"
              alt="Electrical & HVAC Services"
              class="w-full h-[400px] md:h-[500px] object-cover"
            />
            <div class="absolute top-4 left-4">
              <span class="inline-flex items-center px-4 py-2 bg-primary-500 text-white text-sm font-semibold rounded-full">
                <span class="mr-2 text-lg"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 20 20"><rect width="20" height="20" fill="none"/><g fill="currentColor"><path d="M12.187 10H16a.5.5 0 0 1 .325.88l-4.958 4.241l-5.024 4.743c-.39.368-1.007-.053-.807-.55L8.474 12H6a.5.5 0 0 1-.46-.697l3-7A.5.5 0 0 1 9 4h5a.5.5 0 0 1 .46.697z" opacity="0.2"/><path fill-rule="evenodd" d="M15 8.5h-3.813l2.273-5.303A.5.5 0 0 0 13 2.5H8a.5.5 0 0 0-.46.303l-3 7A.5.5 0 0 0 5 10.5h2.474l-2.938 7.314c-.2.497.417.918.807.55l5.024-4.743l4.958-4.241A.5.5 0 0 0 15 8.5m-4.571 1h3.217l-3.948 3.378l-3.385 3.195l2.365-5.887a.5.5 0 0 0-.464-.686H5.758l2.572-6h3.912L9.969 8.803a.5.5 0 0 0 .46.697" clip-rule="evenodd"/></g></svg></span>
                Electrical & HVAC
              </span>
            </div>
          </div>
        </div>
        
        <div class="order-1 lg:order-2">
          <div class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4">
            Expertise Area
          </div>
          <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-6">
            Electrical & <span class="text-primary-600">HVAC Systems</span>
          </h2>
          <p class="text-lg text-slate-600 mb-6">
            Complete electrical and HVAC solutions for industrial, commercial, and residential applications.
          </p>
          
          <div class="space-y-4">
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Building Electrical</strong> - Complete electrical solutions for buildings</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Industrial Electrical</strong> - Heavy duty electrical systems for industries</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Substation Work</strong> - Complete substation electrical work</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>Solar Electrical</strong> - AC, DC, ICR, IDT all electrical work for solar projects</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>HVAC Maintenance</strong> - Complete HVAC system maintenance</span>
            </div>
            <div class="flex items-start">
              <svg class="w-5 h-5 text-primary-500 mt-1 mr-3 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
              <span class="text-slate-700"><strong>HVAC Operation</strong> - Professional HVAC system operation services</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Additional Services Section -->
  <section  id="maintenance" class="section bg-slate-50">
    <div class="container mx-auto px-4 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <div class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4">
          Additional Services
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          Our <span class="text-primary-600">Support Services</span>
        </h2>
        <p class="text-lg text-slate-600">
          Beyond core engineering, we provide comprehensive support services for complete project success.
        </p>
      </div>
      
