---
import Layout from "../layouts/Layout.astro";
import { data } from "../utils/constant.ts";
---

<Layout 
  title="Contact Elite Elecon | Get a Consultation"
  description="Ready to start your next project? Contact Elite Elecon today for professional engineering consultations and services across India."
>
  <!-- Hero Section -->
  <section
    class="relative bg-gradient-to-r from-primary-900 to-primary-800 text-white py-16 md:py-24"
  >
    <div class="absolute inset-0">
      <img
        src="/contact-us.webp"
        alt="Contact Us Background"
        class="w-full h-full object-cover opacity-20"
      />
    </div>
    <div class="container relative mx-auto px-4 md:px-8">
      <div class="max-w-3xl">
        <div
          class="inline-flex items-center px-4 py-2 bg-white/20 text-white rounded-full text-sm font-semibold mb-4"
        >
          Contact Us
        </div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold mb-6">
          Get In <span class="text-primary-300">Touch</span>
        </h1>
        <p class="text-lg md:text-xl text-primary-100 mb-8">
          Ready to start your next project? Contact Elite Elecon today for
          professional consultation and exceptional engineering solutions across
          India.
        </p>
      </div>
    </div>
  </section>

  <!-- Contact Info Section -->
  <section class="section bg-gradient-to-r from-slate-100 to-white">
    <div class="container mx-auto px-4 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <div
          class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4"
        >
          Get In Touch
        </div>
        <h2 class="text-3xl md:text-4xl font-bold mb-6">
          Ready to Start Your Next Project?
        </h2>
        <p class="text-xl text-slate-600">
          Let's discuss how Elite Elecon can help bring your construction and
          engineering projects to life with precision and excellence.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8 text-white">
        <!-- Phone Contact -->
        <div
          class="bg-primary-600 backdrop-blur-sm rounded-2xl p-6 text-center group hover:bg-primary-700 transition-all duration-300"
        >
          <div
            class="w-16 h-16 flex items-center justify-center bg-white rounded-full mx-auto mb-4 group-hover:scale-110 transition-transform duration-300 text-primary-500"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Call Us</h3>
          <div class="space-y-2">
            <a
              href={"tel:" + data.mobile}
              class="block text-lg font-semibold hover:text-primary-200 transition-colors"
            >
              {data.mobile}
            </a>
            <a
              href={"tel:" + data.mobile2}
              class="block text-lg font-semibold hover:text-primary-200 transition-colors"
            >
              {data.mobile2}
            </a>
          </div>
          <p class="text-sm text-primary-100 mt-3">
            Available during business hours
          </p>
        </div>

        <!-- Email Contact -->
        <div
          class="bg-primary-600 backdrop-blur-sm rounded-2xl p-6 text-center group hover:bg-primary-700 transition-all duration-300"
        >
          <div
            class="w-16 h-16 flex items-center justify-center bg-white rounded-full mx-auto mb-4 group-hover:scale-110 transition-transform duration-300 text-primary-500"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"
              ></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Email Us</h3>
          <a
            href={"mailto:" + data.email}
            class="text-lg font-semibold hover:text-primary-200 transition-colors block break-all"
          >
            {data.email}
          </a>
          <p class="text-sm text-primary-100 mt-3">
            We respond within 24 hours
          </p>
        </div>

        <!-- Address -->
        <div
          class="bg-primary-600 backdrop-blur-sm rounded-2xl p-6 text-center group hover:bg-primary-700 transition-all duration-300"
        >
          <div
            class="w-16 h-16 flex items-center justify-center bg-white rounded-full mx-auto mb-4 group-hover:scale-110 transition-transform duration-300 text-primary-500"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"
              ></path>
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Visit Us</h3>
          <p class="text-lg font-semibold">{data.address}</p>
          <p class="text-sm text-primary-100 mt-3">Industrial Area</p>
        </div>

        <!-- Business Hours -->
        <div
          class="bg-primary-600 backdrop-blur-sm rounded-2xl p-6 text-center group hover:bg-primary-700 transition-all duration-300"
        >
          <div
            class="w-16 h-16 flex items-center justify-center bg-white rounded-full mx-auto mb-4 group-hover:scale-110 transition-transform duration-300 text-primary-500"
          >
            <svg
              class="w-8 h-8"
              fill="none"
              stroke="currentColor"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                stroke-width="2"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
            </svg>
          </div>
          <h3 class="text-xl font-bold mb-2">Business Hours</h3>
          <p class="text-lg font-semibold">{data.businessHours}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Departments Section -->
  <section class="section bg-slate-50">
    <div class="container mx-auto px-4 md:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12">
        <div
          class="inline-flex items-center px-4 py-2 bg-primary-50 text-primary-700 rounded-full text-sm font-semibold mb-4"
        >
          Our Departments
        </div>
        <h2 class="text-3xl md:text-4xl font-bold text-slate-900 mb-4">
          Contact <span class="text-primary-600">Specific Departments</span>
        </h2>
        <p class="text-lg text-slate-600">
          Get in touch with the right team for your specific requirements.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Civil Department -->
        <div
          class="bg-white rounded-xl p-6 border border-slate-200 hover:border-primary-300 hover:shadow-lg transition-all duration-300"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-12 h-12 flex items-center justify-center bg-primary-100 text-primary-700 rounded-lg mr-4"
            >
              <span class="text-2xl"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 32 32"><rect width="32" height="32" fill="none"/><path fill="currentColor" d="M4 4a1 1 0 0 1 1-1h22a1 1 0 1 1 0 2h-3c0 .556-.404 1-.91 1h-.59v3.09c.85.23 1.48 1.02 1.48 1.94c0 .696-.36 1.312-.903 1.67l.92 1.3h4.489a.51.51 0 0 1 .514.5a.5.5 0 0 1-.504.5H28v3h.486a.51.51 0 0 1 .514.5a.51.51 0 0 1-.514.5h-1.018a.49.49 0 0 1-.208.48c-.09.06-.19.09-.29.09c-.16 0-.31-.07-.41-.21l-.255-.36h-8.65l-.255.36c-.1.14-.25.21-.41.21c-.1 0-.2-.03-.29-.09a.49.49 0 0 1-.208-.48h-.978a.51.51 0 0 1-.514-.5c0-.274.232-.5.514-.5H16v-3h-.486a.51.51 0 0 1-.514-.5c0-.274.232-.5.514-.5h4.45l.92-1.3a2 2 0 0 1-.904-1.67c0-.28.23-.5.5-.5c.28 0 .5.22.5.5c0 .36.193.678.481.854l.085-.12a.5.5 0 0 1 .079-.1a.5.5 0 0 1 .355-.147c.13-.001.26.05.355.147a.5.5 0 0 1 .08.1l.084.12c.288-.176.481-.494.481-.854c0-.55-.43-.99-.98-1c-.17 0-.33-.09-.42-.23a.44.44 0 0 1-.09-.27c0-.04 0-.07.01-.11V6h-.59c-.506 0-.91-.444-.91-1h-6v21h.75c.69 0 1.25.56 1.25 1.25V28h12.01c1.1 0 1.99.895 1.99 2H2c0-1.105.89-2 1.99-2H5v-.75c0-.69.56-1.25 1.25-1.25H7V5H5a1 1 0 0 1-1-1m4 3v2.191L12.382 7zm.618 19H13v-2.191zm3.764-3H8v2.191zM8.618 10H13V7.809zm3.764 1H8v2.191zm-3.764 3H13v-2.191zm3.764 1H8v2.191zm-3.764 3H13v-2.191zm3.764 1H8v2.191zm-3.764 3H13v-2.191zm13.264-8.972l-.688.972h1.572l-.688-.972a2 2 0 0 1-.196 0M19.256 15H17v3h.132zm-.893 3h7.234l-2.123-3h-2.988zm6.342-3l2.123 3H27v-3z"/></svg></span>
            </div>
            <h3 class="text-xl font-bold text-slate-900">Civil Department</h3>
          </div>
          <p class="text-slate-600 mb-4">
            For all civil construction, foundation work, road construction, and
            building projects.
          </p>
          <div class="space-y-2">
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.343c2.673 0 4.012-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187a1.993 1.993 0 00-.114-.035l1.063-1.063A3 3 0 009 8.172z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Civil Construction</span>
            </div>
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.343c2.673 0 4.012-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187a1.993 1.993 0 00-.114-.035l1.063-1.063A3 3 0 009 8.172z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Foundation Work</span>
            </div>
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M7 2a1 1 0 00-.707 1.707L7 4.414v3.758a1 1 0 01-.293.707l-4 4C.817 14.769 2.156 18 4.828 18h10.343c2.673 0 4.012-3.231 2.122-5.121l-4-4A1 1 0 0113 8.172V4.414l.707-.707A1 1 0 0013 2H7zm2 6.172V4h2v4.172a3 3 0 00.879 2.12l1.027 1.028a4 4 0 00-2.171.102l-.47.156a4 4 0 01-2.53 0l-.563-.187a1.993 1.993 0 00-.114-.035l1.063-1.063A3 3 0 009 8.172z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Road Construction</span>
            </div>
          </div>
        </div>

        <!-- Mechanical Department -->
        <div
          class="bg-white rounded-xl p-6 border border-slate-200 hover:border-primary-300 hover:shadow-lg transition-all duration-300"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-12 h-12 flex items-center justify-center bg-primary-100 text-primary-700 rounded-lg mr-4"
            >
              <span class="text-2xl"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 256 256"><rect width="256" height="256" fill="none"/><g fill="currentColor"><path d="m207.86 123.18l16.78-21a99 99 0 0 0-10.07-24.29l-26.7-3a81 81 0 0 0-6.81-6.81l-3-26.71a99.4 99.4 0 0 0-24.3-10l-21 16.77a82 82 0 0 0-9.64 0l-21-16.78a99 99 0 0 0-24.21 10.07l-3 26.7a81 81 0 0 0-6.81 6.81l-26.71 3a99.4 99.4 0 0 0-10 24.3l16.77 21a82 82 0 0 0 0 9.64l-16.78 21a99 99 0 0 0 10.07 24.29l26.7 3a81 81 0 0 0 6.81 6.81l3 26.71a99.4 99.4 0 0 0 24.3 10l21-16.77a82 82 0 0 0 9.64 0l21 16.78a99 99 0 0 0 24.29-10.07l3-26.7a81 81 0 0 0 6.81-6.81l26.71-3a99.4 99.4 0 0 0 10-24.3l-16.77-21a82 82 0 0 0-.08-9.64M128 168a40 40 0 1 1 40-40a40 40 0 0 1-40 40" opacity="0.2"/><path d="M128 80a48 48 0 1 0 48 48a48.05 48.05 0 0 0-48-48m0 80a32 32 0 1 1 32-32a32 32 0 0 1-32 32m88-29.84q.06-2.16 0-4.32l14.92-18.64a8 8 0 0 0 1.48-7.06a107.6 107.6 0 0 0-10.88-26.25a8 8 0 0 0-6-3.93l-23.72-2.64q-1.48-1.56-3-3L186 40.54a8 8 0 0 0-3.94-6a107.3 107.3 0 0 0-26.25-10.86a8 8 0 0 0-7.06 1.48L130.16 40h-4.32L107.2 25.11a8 8 0 0 0-7.06-1.48a107.6 107.6 0 0 0-26.25 10.88a8 8 0 0 0-3.93 6l-2.64 23.76q-1.56 1.49-3 3L40.54 70a8 8 0 0 0-6 3.94a107.7 107.7 0 0 0-10.87 26.25a8 8 0 0 0 1.49 7.06L40 125.84v4.32L25.11 148.8a8 8 0 0 0-1.48 7.06a107.6 107.6 0 0 0 10.88 26.25a8 8 0 0 0 6 3.93l23.72 2.64q1.49 1.56 3 3L70 215.46a8 8 0 0 0 3.94 6a107.7 107.7 0 0 0 26.25 10.87a8 8 0 0 0 7.06-1.49L125.84 216q2.16.06 4.32 0l18.64 14.92a8 8 0 0 0 7.06 1.48a107.2 107.2 0 0 0 26.25-10.88a8 8 0 0 0 3.93-6l2.64-23.72q1.56-1.48 3-3l23.78-2.8a8 8 0 0 0 6-3.94a107.7 107.7 0 0 0 10.87-26.25a8 8 0 0 0-1.49-7.06Zm-16.1-6.5a74 74 0 0 1 0 8.68a8 8 0 0 0 1.74 5.48l14.19 17.73a91.6 91.6 0 0 1-6.23 15l-22.6 2.56a8 8 0 0 0-5.1 2.64a74 74 0 0 1-6.14 6.14a8 8 0 0 0-2.64 5.1l-2.51 22.58a91.3 91.3 0 0 1-15 6.23l-17.74-14.19a8 8 0 0 0-5-1.75h-.48a74 74 0 0 1-8.68 0a8.06 8.06 0 0 0-5.48 1.74l-17.78 14.2a91.6 91.6 0 0 1-15-6.23L82.89 187a8 8 0 0 0-2.64-5.1a74 74 0 0 1-6.14-6.14a8 8 0 0 0-5.1-2.64l-22.58-2.52a91.3 91.3 0 0 1-6.23-15l14.19-17.74a8 8 0 0 0 1.74-5.48a74 74 0 0 1 0-8.68a8 8 0 0 0-1.74-5.48L40.2 100.45a91.6 91.6 0 0 1 6.23-15L69 82.89a8 8 0 0 0 5.1-2.64a74 74 0 0 1 6.14-6.14A8 8 0 0 0 82.89 69l2.51-22.57a91.3 91.3 0 0 1 15-6.23l17.74 14.19a8 8 0 0 0 5.48 1.74a74 74 0 0 1 8.68 0a8.06 8.06 0 0 0 5.48-1.74l17.77-14.19a91.6 91.6 0 0 1 15 6.23L173.11 69a8 8 0 0 0 2.64 5.1a74 74 0 0 1 6.14 6.14a8 8 0 0 0 5.1 2.64l22.58 2.51a91.3 91.3 0 0 1 6.23 15l-14.19 17.74a8 8 0 0 0-1.74 5.53Z"/></g></svg></span>
