            <h3 class="text-xl font-bold text-slate-900">
              Mechanical Department
            </h3>
          </div>
          <p class="text-slate-600 mb-4">
            For mechanical services, fabrication, erection, pipeline work, and
            maintenance.
          </p>
          <div class="space-y-2">
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Fabrication & Erection</span>
            </div>
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Pipeline Specialists</span>
            </div>
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Maintenance Work</span>
            </div>
          </div>
        </div>

        <!-- Electrical & HVAC Department -->
        <div
          class="bg-white rounded-xl p-6 border border-slate-200 hover:border-primary-300 hover:shadow-lg transition-all duration-300"
        >
          <div class="flex items-center mb-4">
            <div
              class="w-12 h-12 flex items-center justify-center bg-primary-100 text-primary-700 rounded-lg mr-4"
            >
              <span class="text-2xl"><svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 20 20"><rect width="20" height="20" fill="none"/><g fill="currentColor"><path d="M12.187 10H16a.5.5 0 0 1 .325.88l-4.958 4.241l-5.024 4.743c-.39.368-1.007-.053-.807-.55L8.474 12H6a.5.5 0 0 1-.46-.697l3-7A.5.5 0 0 1 9 4h5a.5.5 0 0 1 .46.697z" opacity="0.2"/><path fill-rule="evenodd" d="M15 8.5h-3.813l2.273-5.303A.5.5 0 0 0 13 2.5H8a.5.5 0 0 0-.46.303l-3 7A.5.5 0 0 0 5 10.5h2.474l-2.938 7.314c-.2.497.417.918.807.55l5.024-4.743l4.958-4.241A.5.5 0 0 0 15 8.5m-4.571 1h3.217l-3.948 3.378l-3.385 3.195l2.365-5.887a.5.5 0 0 0-.464-.686H5.758l2.572-6h3.912L9.969 8.803a.5.5 0 0 0 .46.697" clip-rule="evenodd"/></g></svg></span>
            </div>
            <h3 class="text-xl font-bold text-slate-900">Electrical & HVAC</h3>
          </div>
          <p class="text-slate-600 mb-4">
            For electrical works, HVAC systems, solar projects, and electrical
            maintenance.
          </p>
          <div class="space-y-2">
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>Electrical Works</span>
            </div>
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
                <path
                  fill-rule="evenodd"
                  d="M11.3 1.046A1 1 0 0112 2v5h4a1 1 0 01.82 1.573l-7 10A1 1 0 018 18v-5H4a1 1 0 01-.82-1.573l7-10a1 1 0 011.12-.38z"
                  clip-rule="evenodd"></path>
              </svg>
              <span>HVAC Systems</span>
            </div>
            <div class="flex items-center text-slate-700">
              <svg
                class="w-4 h-4 text-primary-500 mr-2"
                fill="currentColor"
                viewBox="0 0 20 20"
              >
